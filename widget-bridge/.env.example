# ============================================================
# Chatwoot Widget Bridge — Environment Configuration
# ============================================================
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# === Chatwoot ===
# Public URL of your Chatwoot instance (must support HTTPS)
CHATWOOT_BASE_URL=https://chat.example.com
# Generate from Chatwoot UI: Profile Settings → Access Token
CHATWOOT_API_TOKEN=your_chatwoot_user_api_token_here
CHATWOOT_ACCOUNT_ID=1
# Inbox ID of the WebWidget (the source — visitors fill the form here)
WIDGET_INBOX_ID=3
# Inbox ID of the WhatsApp Cloud API channel (where the OOH template is sent)
WHATSAPP_INBOX_ID=5

# === WhatsApp Template ===
# Must be APPROVED in Meta WhatsApp Business Manager
# Recommended: UTILITY category (cheaper, less restricted than MARKETING)
TEMPLATE_NAME=website_ooh_v1
TEMPLATE_LANGUAGE=ar
TEMPLATE_CATEGORY=UTILITY

# === Working Hours (Asia/Riyadh) ===
TIMEZONE=Asia/Riyadh
OPEN_HOUR=9
CLOSE_HOUR=23
CLOSE_MINUTE=59
# Closed days (Python weekday: Mon=0, Tue=1, Wed=2, Thu=3, Fri=4, Sat=5, Sun=6)
# Saudi standard: Friday closed → [4]
CLOSED_DAYS=[4]

# === Redis (24h dedup) ===
# Use a dedicated DB index (e.g. /3) to avoid colliding with Chatwoot's own keys
REDIS_URL=redis://:your_redis_password@chatwoot-redis:6379/3
DEDUP_TTL_SECONDS=86400

# === Webhook Security ===
# Generate with: openssl rand -hex 32
# Used as path token: /webhook/chatwoot/{secret}
WEBHOOK_SECRET=generate_64_byte_hex_secret_here

# === Behavior Toggles ===
# Set DRY_RUN=true while testing. Flip to false for production.
DRY_RUN=true
SEND_INTERNAL_NOTE=true
ADD_TAG=true
TAG_NAME=from_website
OOH_LABEL=after_hours

# === Stats Buffer ===
STATS_BUFFER_SIZE=200
