<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="ar" dir="rtl" style="margin:0; box-sizing:border-box; font-size:14px;">
  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>{{ global_config['BRAND_NAME'] }}</title>
    <style type="text/css">
      @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap');
      img { max-width: 100%; border: 0; }
      body {
        -webkit-font-smoothing: antialiased; -webkit-text-size-adjust: none;
        width: 100% !important; height: 100%; line-height: 1.7em;
        background-color: #F4F6F3; margin: 0;
        font-family: 'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      a { color: #6B7F5C; }
      .qd-content a { color: #6B7F5C; }
      @media only screen and (max-width: 640px) {
        body { padding: 0 !important; }
        .container { padding: 0 !important; width: 100% !important; }
        .content { padding: 12px !important; }
        .content-wrap { padding: 22px !important; }
        h1 { font-size: 21px !important; }
      }
    </style>
  </head>
  <body dir="rtl" style="font-family:'Cairo',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif; -webkit-font-smoothing:antialiased; width:100% !important; height:100%; line-height:1.7em; background-color:#F4F6F3; margin:0;" bgcolor="#F4F6F3">
    <table class="body-wrap" width="100%" cellpadding="0" cellspacing="0" style="width:100%; background-color:#F4F6F3; margin:0;" bgcolor="#F4F6F3">
      <tr>
        <td class="container" width="600" style="display:block !important; max-width:600px !important; margin:0 auto;" valign="top">
          <div class="content" style="display:block; margin:0 auto; padding:24px; text-align:center;">

            <!-- Logo header -->
            <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 18px;">
              <tr><td align="center" style="padding:8px 0 18px;">
                <a href="{{ global_config['BRAND_URL'] }}" target="_blank" style="text-decoration:none;">
                  <img src="https://track.qaydao.com/logo-qaydao.png" alt="QAYDAO" width="170" style="width:170px; max-width:170px; height:auto; display:inline-block;" />
                </a>
              </td></tr>
            </table>

            <!-- Main card -->
            <table class="main" width="100%" cellpadding="0" cellspacing="0" style="border-radius:14px; background-color:#ffffff; text-align:right; margin:0; border:1px solid #E8EDE5; border-top:4px solid #6B7F5C; box-shadow:0 2px 8px rgba(107,127,92,0.06);" bgcolor="#ffffff">
              <tr>
                <td class="content-wrap qd-content" dir="rtl" style="vertical-align:top; margin:0; padding:30px; text-align:right; color:#374151; font-size:15px; line-height:1.8;" valign="top">
                  <table width="100%" cellpadding="0" cellspacing="0" style="margin:0;">
                    {{ content_for_layout }}
                  </table>
                </td>
              </tr>
            </table>

            <!-- Footer -->
            <div class="footer" style="color:#8A9A7B; margin:0; padding:24px 20px 36px; text-align:center; font-size:13px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0;">
                <tr><td align="center" style="padding:0 0 10px; color:#6B7F5C; font-weight:600; font-size:14px;">
                  كواي داو — أثاثٌ يليق بك
                </td></tr>
                <tr><td align="center" style="padding:0 0 6px; color:#7A8A6B;">
                  <a href="https://qaydao.com" target="_blank" style="color:#6B7F5C; text-decoration:none;">qaydao.com</a>
                  &nbsp;•&nbsp;
                  <a href="mailto:support@qaydao.com" style="color:#6B7F5C; text-decoration:none;">support@qaydao.com</a>
                  &nbsp;•&nbsp;
                  <span dir="ltr">+966 54 845 6966</span>
                </td></tr>
                <tr><td align="center" style="padding:10px 0 0; color:#A9B89C; font-size:12px;">
                  © {{ 'now' | date: '%Y' }} QAYDAO. جميع الحقوق محفوظة.
                </td></tr>
              </table>
            </div>

          </div>
        </td>
      </tr>
    </table>
  </body>
</html>
